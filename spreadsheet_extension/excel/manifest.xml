<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp 
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" 
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" 
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp">

  <!-- Core Metadata -->
  <Id>d2c3bf9c-ea2b-4d43-a60d-9b50302b1f89</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>UltraSearch Corp</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="UltraSearch Research" />
  <Description DefaultValue="An AI-powered web research assistant that executes background query pipelines and populates results inside your spreadsheets."/>
  
  <IconUrl DefaultValue="http://localhost:8050/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="http://localhost:8050/assets/icon-80.png" />
  <SupportUrl DefaultValue="http://localhost:8050/support" />
  
  <!-- Host Support -->
  <Hosts>
    <Host Name="Workbook" />
  </Hosts>
  
  <!-- Requirements and Permissions -->
  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="ExcelApi" MinVersion="1.1"/>
      <Set Name="CustomFunctionsRuntime" MinVersion="1.1"/>
    </Sets>
  </Requirements>
  
  <DefaultSettings>
    <SourceLocation DefaultValue="http://localhost:8050/sidebar.html" />
  </DefaultSettings>
  
  <Permissions>ReadWriteDocument</Permissions>
  
  <!-- Visuals and Integration Overrides -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Description resid="Desc.Resid" />
    
    <Hosts>
      <Host xsi:type="Workbook">
        <!-- Register Custom Functions -->
        <AllFormFactors>
          <ExtensionPoint xsi:type="CustomFunctions">
            <Script>
              <SourceLocation resid="Functions.Script.Url"/>
            </Script>
            <Page>
              <SourceLocation resid="Functions.Page.Url"/>
            </Page>
            <Metadata>
              <SourceLocation resid="Functions.Metadata.Url"/>
            </Metadata>
            <Namespace resid="Functions.Namespace"/>
          </ExtensionPoint>
        </AllFormFactors>

        <!-- Command surface task pane button -->
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title"/>
            <Description resid="GetStarted.Description"/>
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
          </GetStarted>
          
          <FunctionFile resid="FuncFile.Url" />
          
          <!-- Ribbon Customization -->
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <CustomTab id="UltraSearchTab">
              <Group id="ResearchGroup">
                <Label resid="Group.Label" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
                  <bt:Image size="32" resid="Icon.32x32" />
                  <bt:Image size="80" resid="Icon.80x80" />
                </Icon>
                <Control xsi:type="Button" id="OpenSidebarButton">
                  <Label resid="Button.Label" />
                  <Supertip>
                    <Title resid="Button.TooltipTitle" />
                    <Description resid="Button.TooltipDesc" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>UltraSearchTaskpane</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
              <Label resid="Tab.Label" />
            </CustomTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    
    <!-- String / URL Resource Registries -->
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="http://localhost:8050/assets/icon-16.png" />
        <bt:Image id="Icon.32x32" DefaultValue="http://localhost:8050/assets/icon-32.png" />
        <bt:Image id="Icon.80x80" DefaultValue="http://localhost:8050/assets/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="FuncFile.Url" DefaultValue="http://localhost:8050/excel/functions.html" />
        <bt:Url id="Taskpane.Url" DefaultValue="http://localhost:8050/sidebar.html" />
        
        <!-- Custom Functions Resources -->
        <bt:Url id="Functions.Script.Url" DefaultValue="http://localhost:8050/excel/functions.js" />
        <bt:Url id="Functions.Page.Url" DefaultValue="http://localhost:8050/excel/functions.html" />
        <bt:Url id="Functions.Metadata.Url" DefaultValue="http://localhost:8050/excel/functions-metadata.json" />
        <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="http://localhost:8050/harness.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="Functions.Namespace" DefaultValue="ULTRA" />
        <bt:String id="Desc.Resid" DefaultValue="AI Web Research and Extraction Engine." />
        <bt:String id="GetStarted.Title" DefaultValue="Get started with UltraSearch!" />
        <bt:String id="Group.Label" DefaultValue="AI Research Tools" />
        <bt:String id="Button.Label" DefaultValue="Research Sidebar" />
        <bt:String id="Button.TooltipTitle" DefaultValue="Launch UltraSearch Sidebar" />
        <bt:String id="Tab.Label" DefaultValue="UltraSearch" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="Execute research pipelines on rows of data directly from Excel." />
        <bt:String id="Button.TooltipDesc" DefaultValue="Opens the glassmorphic sidebar panel to trigger AI data extraction pipelines." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
