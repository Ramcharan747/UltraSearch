{
  "name": "vscode-ultrasearch",
  "displayName": "UltraSearch Web Intelligence",
  "description": "Tavily Alternative: Unrestricted stealth web scraping and search engine for AI Agents",
  "version": "2.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ultrasearch.search",
        "title": "UltraSearch: Deep Web Search (Extract Page Contents)"
      },
      {
        "command": "ultrasearch.fastSearch",
        "title": "UltraSearch: AI Overview & 10 URLs (Fast Browser)"
      },
      {
        "command": "ultrasearch.quickUrls",
        "title": "UltraSearch: Quick 10 URLs & Snippets (Fast HTTP)"
      },
      {
        "command": "ultrasearch.onlyAI",
        "title": "UltraSearch: Only AI Overview (Fast Browser)"
      }
    ],
    "configuration": {
      "title": "UltraSearch Settings",
      "properties": {
        "ultrasearch.filterProfile": {
          "type": "string",
          "default": "browser",
          "description": "Name of the filter profile to use"
        },
        "ultrasearch.hl": {
          "type": "string",
          "default": "",
          "description": "Language filter override (e.g. 'en', 'hi')"
        },
        "ultrasearch.gl": {
          "type": "string",
          "default": "",
          "description": "Country/region override (e.g. 'us', 'in')"
        },
        "ultrasearch.uule": {
          "type": "string",
          "default": "",
          "description": "Geolocation (uule) override"
        },
        "ultrasearch.safe": {
          "type": "string",
          "default": "",
          "description": "SafeSearch override (active, off, browser)"
        },
        "ultrasearch.tbs": {
          "type": "string",
          "default": "",
          "description": "Search tools override (e.g. qdr:d)"
        }
      }
    }
  },
  "activationEvents": []
}
